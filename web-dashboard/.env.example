# --- Local development (recommended) ---
# Proxy API calls through Vite (see vite.config.js). No CORS issues.
DEV_PROXY_TARGET=https://carotidcheck-api.onrender.com
# Leave VITE_API_URL unset so the app uses same-origin /proxy paths.

# --- Or call the API directly from the browser ---
# VITE_API_URL=https://carotidcheck-api.onrender.com

# --- Local backend only ---
# VITE_API_URL=http://localhost:8000
# DEV_PROXY_TARGET=http://localhost:8000
