# --- Local development (recommended) ---
# Proxy API calls through Vite (see vite.config.js). No CORS issues.
DEV_PROXY_TARGET=https://carotidcheck-api.onrender.com
# Leave VITE_API_URL unset so the app uses same-origin /proxy paths.

# --- Or call the API directly from the browser ---
# VITE_API_URL=https://carotidcheck-api.onrender.com

# --- Local backend only ---
# VITE_API_URL=http://localhost:8000
# DEV_PROXY_TARGET=http://localhost:8000

# --- Playwright E2E (real API; do not commit secrets) ---
# Credentials must exist on the API (deployed or E2E_API_URL below).
# E2E_IDENTIFIER=staff@example.com
# E2E_PASSWORD=...
# Optional: override API baked into the preview build (default: prod URL in AuthContext when unset).
# E2E_API_URL=https://carotidcheck-api.onrender.com
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
# E2E_PREVIEW_PORT=4173
