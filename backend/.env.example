# Copy to ../.env at repo root (backend loads from parent .env via config.py)

# --- Email (Gmail example: password reset + CHW ID on register when email provided) ---
# Create an App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=checkcarid@gmail.com
SMTP_PASSWORD=your-16-char-app-password
# From address (defaults to checkcarid@gmail.com if unset; should match SMTP_USER for Gmail)
EMAIL_FROM=checkcarid@gmail.com

# Password reset links open this site (must match deployed dashboard URL)
# PASSWORD_RESET_BASE_URL=https://carotidcheck-dashboard.onrender.com
