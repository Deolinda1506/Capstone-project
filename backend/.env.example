# Copy to ../.env at repo root (backend loads from parent .env via config.py)

# --- Email (Gmail example: password reset + CHW ID on register when email provided) ---
# Create an App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=checkcarid@gmail.com
SMTP_PASSWORD=your-16-char-app-password
# From address (defaults to checkcarid@gmail.com if unset; should match SMTP_USER for Gmail)
EMAIL_FROM=checkcarid@gmail.com

# Password reset links open this site (must match deployed dashboard URL)
# PASSWORD_RESET_BASE_URL=https://carotidcheck-dashboard.onrender.com

# --- CORS (Flutter web origin, etc.) ---
# Example:
# CORS_ORIGINS=http://localhost:5173,http://localhost:55994,https://carotidcheck-dashboard.onrender.com
# Leave empty to allow all origins (dev convenience).
CORS_ORIGINS=

# --- Alert queue (reliable retries for SMS/email) ---
# When enabled, SMS/email delivery is enqueued in the DB and retried by the API worker.
ALERT_QUEUE_ENABLED=1
ALERT_QUEUE_POLL_SECONDS=5
ALERT_QUEUE_MAX_ATTEMPTS=5
ALERT_QUEUE_MAX_BATCH_SIZE=20
# Backoff multiplier in seconds: next_attempt = now + base * attempts
ALERT_QUEUE_BACKOFF_BASE_SECONDS=2
